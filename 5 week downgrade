$pauseDate = (Get-Date).AddDays(35).ToUniversalTime().ToString('yyyy-MM-ddTHH:mm:ssZ'); $path = 'HKLM:\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings'; if (!(Test-Path $path)) { New-Item -Path $path -Force | Out-Null }; Set-ItemProperty -Path $path -Name 'PauseUpdatesExpiryTime' -Value $pauseDate -Type String -Force; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate\Auto Update' -Name 'AUOptions' -Value 1 -Type DWord -Force; Write-Host "Paused until $pauseDate (5 weeks). Auto-updates OFF." -ForegroundColor Green
